{% extends "base.html" %}

{% block title %}UniLab - Layout Optimizer{% endblock %}

{% block scripts %}
<style>
    .layout-container {
        display: flex;
        gap: 16px;
        height: calc(100vh - 120px);
        min-height: 600px;
    }
    /* --- Canvas Area --- */
    .canvas-panel {
        flex: 3;
        position: relative;
        background: #1a1a2e;
        border-radius: 8px;
        overflow: hidden;
    }
    #layoutCanvas {
        width: 100%;
        height: 100%;
        cursor: crosshair;
    }
    .canvas-toolbar {
        position: absolute;
        top: 10px;
        left: 10px;
        display: flex;
        gap: 6px;
        z-index: 10;
    }
    .canvas-toolbar button {
        background: rgba(255,255,255,0.15);
        color: #fff;
        border: 1px solid rgba(255,255,255,0.25);
        padding: 6px 12px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 13px;
        backdrop-filter: blur(4px);
    }
    .canvas-toolbar button:hover { background: rgba(255,255,255,0.25); }
    .canvas-toolbar button.active { background: rgba(33,150,243,0.6); border-color: #2196F3; }
    .canvas-info {
        position: absolute;
        bottom: 10px;
        left: 10px;
        color: rgba(255,255,255,0.6);
        font-size: 12px;
        font-family: monospace;
    }
    .canvas-legend {
        position: absolute;
        bottom: 10px;
        right: 10px;
        display: flex;
        gap: 12px;
        color: rgba(255,255,255,0.7);
        font-size: 11px;
    }
    .legend-item { display: flex; align-items: center; gap: 4px; }
    .legend-swatch {
        width: 14px; height: 14px; border-radius: 3px;
        border: 1px solid rgba(255,255,255,0.3);
    }

    /* --- Control Panel --- */
    .control-panel {
        flex: 1;
        min-width: 300px;
        max-width: 380px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        overflow-y: auto;
    }
    .panel-section {
        background: #f8f9fa;
        border-radius: 6px;
        padding: 14px;
        border: 1px solid #e9ecef;
    }
    .panel-section h3 {
        margin: 0 0 10px 0;
        font-size: 14px;
        color: #495057;
        border-bottom: 1px solid #dee2e6;
        padding-bottom: 6px;
    }
    .panel-section label {
        display: block;
        font-size: 12px;
        color: #6c757d;
        margin-bottom: 3px;
    }
    .panel-section input, .panel-section select, .panel-section textarea {
        width: 100%;
        padding: 6px 8px;
        border: 1px solid #ced4da;
        border-radius: 4px;
        font-size: 13px;
        box-sizing: border-box;
        margin-bottom: 8px;
    }
    .panel-section textarea {
        font-family: monospace;
        resize: vertical;
        min-height: 60px;
    }
    .btn {
        display: inline-block;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-primary { background: #2196F3; color: #fff; }
    .btn-primary:hover { background: #1976D2; }
    .btn-success { background: #4CAF50; color: #fff; }
    .btn-success:hover { background: #388E3C; }
    .btn-warning { background: #FF9800; color: #fff; }
    .btn-warning:hover { background: #F57C00; }
    .btn-danger { background: #f44336; color: #fff; }
    .btn-danger:hover { background: #d32f2f; }
    .btn-sm { padding: 4px 10px; font-size: 12px; }
    .btn-block { display: block; width: 100%; text-align: center; }

    .device-list {
        max-height: 200px;
        overflow-y: auto;
        font-size: 12px;
    }
    .device-item {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px 6px;
        border-radius: 3px;
        cursor: pointer;
    }
    .device-item:hover { background: #e9ecef; }
    .device-item.selected { background: #d4e6f9; }
    .device-dot {
        width: 10px; height: 10px; border-radius: 50%;
        border: 1px solid rgba(0,0,0,0.2);
        flex-shrink: 0;
    }

    .intent-list { font-size: 12px; }
    .intent-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 4px 6px;
        border-bottom: 1px solid #eee;
    }
    .intent-tag {
        background: #e3f2fd;
        color: #1565C0;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 11px;
    }

    #optimizeLog {
        background: #263238;
        color: #aed581;
        font-family: monospace;
        font-size: 11px;
        padding: 8px;
        border-radius: 4px;
        max-height: 150px;
        overflow-y: auto;
        white-space: pre-wrap;
    }

    .cost-badge {
        display: inline-block;
        background: #fff3e0;
        color: #e65100;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

    /* Responsive */
    @media (max-width: 900px) {
        .layout-container { flex-direction: column; height: auto; }
        .canvas-panel { min-height: 400px; }
        .control-panel { max-width: none; }
    }
</style>
{% endblock %}

{% block header %}Layout Optimizer{% endblock %}

{% block nav %}
<div class="nav-tabs">
    <a href="/" class="nav-tab">Home</a>
    <a href="/status" class="nav-tab">Status</a>
    <a href="/layout" class="nav-tab" style="background:#2196F3;color:#fff;">Layout</a>
</div>
{% endblock %}

{% block content %}
<div class="layout-container">
    <!-- Canvas -->
    <div class="canvas-panel">
        <canvas id="layoutCanvas"></canvas>
        <div class="canvas-toolbar">
            <button id="btnZoomFit" title="Zoom to Fit">Fit</button>
            <button id="btnToggleWorkspace" class="active" title="Toggle Workspace">Workspace</button>
            <button id="btnToggleLinks" class="active" title="Toggle Links">Links</button>
            <button id="btnToggleLabels" class="active" title="Toggle Labels">Labels</button>
            <button id="btnGrid" class="active" title="Toggle Grid">Grid</button>
            <button id="btnToggle3D" title="Toggle 2D/3D">2D</button>
            <button id="btnScreenshot" title="Screenshot">Screenshot</button>
        </div>
        <div class="canvas-info" id="canvasInfo">Ready</div>
        <div class="canvas-legend">
            <div class="legend-item"><div class="legend-swatch" style="background:rgba(0,200,255,0.15);border-color:rgba(0,200,255,0.5)"></div>Arm Workspace</div>
            <div class="legend-item"><div class="legend-swatch" style="background:#5c6bc0"></div>Device</div>
            <div class="legend-item"><div class="legend-swatch" style="background:#66bb6a"></div>Container</div>
            <div class="legend-item"><div class="legend-swatch" style="background:#ef5350"></div>Arm</div>
        </div>
    </div>

    <!-- Control Panel -->
    <div class="control-panel">
        <!-- Station Loader -->
        <div class="panel-section">
            <h3>Station</h3>
            <label>Load Station JSON</label>
            <select id="stationSelect">
                <option value="">-- select --</option>
                {% for station in stations %}
                <option value="{{ station.path }}">{{ station.name }}</option>
                {% endfor %}
            </select>
            <input type="file" id="stationFile" accept=".json" style="font-size:12px;">
            <div style="margin-top:6px;">
                <label>Lab Dimensions (m)</label>
                <div style="display:flex;gap:8px;">
                    <input type="number" id="labWidth" value="2.0" min="0.5" step="0.1" style="width:50%;" placeholder="Width">
                    <input type="number" id="labDepth" value="2.0" min="0.5" step="0.1" style="width:50%;" placeholder="Depth">
                </div>
            </div>
        </div>

        <!-- Device List -->
        <div class="panel-section">
            <h3>Devices <span id="deviceCount" style="color:#999;font-size:12px;"></span></h3>
            <div class="device-list" id="deviceList"></div>
        </div>

        <!-- Intent / Constraints -->
        <div class="panel-section">
            <h3>Constraints</h3>
            <div style="display:flex;gap:6px;margin-bottom:8px;">
                <select id="intentType" style="flex:1;">
                    <option value="reachable_by">reachable_by</option>
                    <option value="close_together">close_together</option>
                    <option value="far_apart">far_apart</option>
                    <option value="min_spacing">min_spacing</option>
                    <option value="max_distance">max_distance</option>
                </select>
                <button class="btn btn-sm btn-primary" id="btnAddIntent">+ Add</button>
            </div>
            <div class="intent-list" id="intentList"></div>
            <button class="btn btn-sm btn-warning btn-block" id="btnAutoIntents" style="margin-top:6px;">
                Auto-generate from Links
            </button>
        </div>

        <!-- Optimizer -->
        <div class="panel-section">
            <h3>Optimizer</h3>
            <div style="display:flex;gap:8px;margin-bottom:8px;">
                <div style="flex:1;">
                    <label>Max Iterations</label>
                    <input type="number" id="maxIter" value="200" min="10" step="10">
                </div>
                <div style="flex:1;">
                    <label>Population</label>
                    <input type="number" id="popSize" value="30" min="5" step="5">
                </div>
            </div>
            <button class="btn btn-success btn-block" id="btnOptimize">
                Optimize Layout
            </button>
            <div style="margin-top:8px;display:flex;justify-content:space-between;align-items:center;">
                <span style="font-size:12px;color:#666;">Cost:</span>
                <span class="cost-badge" id="costDisplay">--</span>
            </div>
        </div>

        <!-- ROS Status (3D mode) -->
        <div class="panel-section" id="rosStatusSection" style="display:none;">
            <h3>ROS Status</h3>
            <div style="font-size:12px;">
                <div id="rosConnStatus" style="padding:2px 0;">Foxglove: --</div>
                <div id="rosJointHz" style="padding:2px 0;">Joint States: --</div>
            </div>
        </div>

        <!-- Log -->
        <div class="panel-section" style="flex:1;min-height:100px;">
            <h3>Log</h3>
            <div id="optimizeLog">Layout optimizer ready.\n</div>
        </div>

        <!-- Export -->
        <div class="panel-section">
            <button class="btn btn-primary btn-block" id="btnExport">Export Station JSON</button>
        </div>
    </div>
</div>

<script src="/static/dist/layout-app.js"></script>
{% endblock %}
